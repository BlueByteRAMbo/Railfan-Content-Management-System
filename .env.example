# ──────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your values
# NEVER commit .env to version control
# ──────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=railfan_archive
POSTGRES_USER=railfan
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters). Use a random generator.
JWT_SECRET=generate-a-very-long-random-secret-key-here-at-least-256-bits
JWT_EXPIRATION_MS=86400000

# ── YouTube Data API v3 ───────────────────────────────────────
# Get your API key from: https://console.cloud.google.com/
# Enable: YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# ── CORS (frontend origin) ────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ── Render Deployment (backend only on Render) ────────────────
# On Render, set these as environment variables in the dashboard:
#
#   PORT             → automatically set by Render (do not change)
#   SPRING_DATASOURCE_URL  → jdbc:postgresql://<host>:<port>/<dbname>
#   SPRING_DATASOURCE_USERNAME → from your Render/Aiven PostgreSQL
#   SPRING_DATASOURCE_PASSWORD → from your Render/Aiven PostgreSQL
#   JWT_SECRET       → your strong random secret
#   YOUTUBE_API_KEY  → your Google API key
#   CORS_ALLOWED_ORIGINS → your frontend URL

# ── Frontend ─────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
